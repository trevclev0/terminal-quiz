# Database file path using URI format
# Example: file:/path/to/database.db or file:./data/app.db
DB_FILE_NAME=file:<FILE_PATH_TO_DB>

# File path to the generated Cloudflare D1 SQLite database file
# Example: .wrangler/state/v3/d1/miniflare-D1DatabaseObject/<HASH>.sqlite
DRIZZLE_DATABASE_URL=<FILE_PATH_TO_CLOUDFLARE_SQLITE_FILE>
