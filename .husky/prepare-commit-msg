#!/usr/bin/env sh

# Skip during rebase or amend ($3 is a SHA in both cases)
[ -n "$3" ] && exit 0

# Only launch Commitizen if a TTY is available (i.e., a real terminal)
if [ -t 1 ]; then
  exec < /dev/tty
  if [ "$CZG_AI_ENABLED" = "true" ] && [ -n "$OPENAI_API_KEY" ]; then
    pnpm czg ai --hook || true
  else
    pnpm cz --hook || true
  fi
fi
