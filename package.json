{
  "name": "terminal-quiz",
  "private": true,
  "version": "2.41.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check:code": "biome check --write .",
    "check": "pnpm build && wrangler deploy --dry-run",
    "cf-typegen": "wrangler types",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "build": "tsc -b && vite build",
    "preview": "pnpm build && vite preview",
    "commit": "git-cz",
    "lint-staged": "lint-staged",
    "prepare": "husky",
    "seed:local": "wrangler d1 execute terminal-quest --local --file=scripts/seed.sql",
    "seed:preview": "wrangler d1 execute terminal-quest-preview --remote --env preview --file=scripts/seed.sql",
    "seed:prod": "wrangler d1 execute terminal-quest --remote --file=scripts/seed.sql",
    "migrate:generate": "drizzle-kit generate",
    "migrate:local": "wrangler d1 migrations apply terminal-quest --local",
    "migrate:preview": "wrangler d1 migrations apply terminal-quest-preview --remote --env preview",
    "migrate:prod": "wrangler d1 migrations apply terminal-quest --remote",
    "deploy": "wrangler deploy",
    "deploy:preview": "wrangler versions upload --remote"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@cloudflare/vite-plugin": "^1.37.1",
    "@cloudflare/workers-types": "^4.20260518.1",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/types": "^20.5.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/ui": "^4.1.6",
    "ajv": "^8.20.0",
    "better-sqlite3": "^12.10.0",
    "commitizen": "^4.3.1",
    "commitlint": "^20.5.2",
    "commitlint-config-gitmoji": "^2.3.1",
    "concurrently": "^9.2.1",
    "cz-git": "^1.13.1",
    "czg": "^1.13.1",
    "date-fns": "^2.30.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "globals": "^17.6.0",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "msw": "^2.14.6",
    "semantic-release": "^25.0.3",
    "semantic-release-gitmoji": "^1.6.9",
    "tsx": "^4.22.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.13",
    "vitest": "^4.1.6",
    "wrangler": "^4.92.0"
  },
  "dependencies": {
    "@hono/graphql-server": "^0.7.0",
    "@hono/zod-validator": "^0.7.6",
    "@msgpack/msgpack": "^3.1.3",
    "@tanstack/react-query": "^5.100.11",
    "@tanstack/react-query-persist-client": "^5.100.11",
    "drizzle-graphql": "^0.8.5",
    "drizzle-orm": "^0.45.2",
    "graphql": "^16.14.0",
    "hono": "^4.12.19",
    "idb-keyval": "^6.2.2",
    "leven": "^4.1.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@11.1.3+sha512.c85357fe17ca12dd23dd7071822666dfd7e3cb76fe214e3370b5ea2fb34f2a231185509b63e717f3cd0acb38dd3f8d82bcd5e8172400ae678b70ea4fbed0896d"
}
