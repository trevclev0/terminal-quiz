{
  "name": "terminal-quiz",
  "private": true,
  "version": "2.44.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check:code": "biome check --write .",
    "check": "pnpm build && wrangler deploy --dry-run",
    "cf-typegen": "wrangler types",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "build": "tsc -b && vite build",
    "preview": "pnpm build && vite preview",
    "commit": "git-cz",
    "lint-staged": "lint-staged",
    "prepare": "husky",
    "seed:local": "wrangler d1 execute terminal-quest --local --file=scripts/seed.sql",
    "seed:preview": "wrangler d1 execute terminal-quest-preview --remote --env preview --file=scripts/seed.sql",
    "seed:prod": "wrangler d1 execute terminal-quest --remote --file=scripts/seed.sql",
    "migrate:generate": "drizzle-kit generate",
    "migrate:local": "wrangler d1 migrations apply terminal-quest --local",
    "migrate:preview": "wrangler d1 migrations apply terminal-quest-preview --remote --env preview",
    "migrate:prod": "wrangler d1 migrations apply terminal-quest --remote",
    "deploy": "wrangler deploy",
    "deploy:preview": "wrangler versions upload --remote"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@cloudflare/vite-plugin": "^1.42.0",
    "@cloudflare/workers-types": "^4.20260619.1",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/types": "^20.5.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@tanstack/router-plugin": "^1.168.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "commitizen": "^4.3.2",
    "commitlint": "^20.5.2",
    "commitlint-config-gitmoji": "^2.3.1",
    "cz-git": "^1.13.1",
    "czg": "^1.13.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "globals": "^17.6.0",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "msw": "^2.14.6",
    "semantic-release": "^25.0.5",
    "semantic-release-gitmoji": "^1.6.9",
    "typescript": "~6.0.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "wrangler": "^4.102.0"
  },
  "dependencies": {
    "@hono/graphql-server": "^0.7.0",
    "@hono/zod-validator": "^0.7.6",
    "@msgpack/msgpack": "^3.1.3",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-persist-client": "^5.101.0",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-router-devtools": "^1.167.0",
    "drizzle-graphql": "^0.8.5",
    "drizzle-orm": "^0.45.2",
    "graphql": "^16.14.2",
    "hono": "^4.12.26",
    "idb-keyval": "^6.2.5",
    "leven": "^4.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
  "dependenciesMeta": {
    "@biomejs/biome@2.4.15": {
      "unplugged": true
    }
  }
}
