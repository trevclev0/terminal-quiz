{
  "name": "terminal-quiz",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "commit": "git-cz",
    "lint-staged": "lint-staged",
    "start": "pnpm build && wrangler pages dev dist",
    "prepare": "husky",
    "seed:local": "wrangler d1 execute terminal-quest --local --file=scripts/seed.sql",
    "seed:preview": "wrangler d1 execute terminal-quest-preview --remote --env preview --file=scripts/seed.sql",
    "seed:prod": "wrangler d1 execute terminal-quest --remote --file=scripts/seed.sql",
    "migrate:generate": "drizzle-kit generate",
    "migrate:local": "wrangler d1 migrations apply terminal-quest --local",
    "migrate:preview": "wrangler d1 migrations apply terminal-quest-preview --remote --env preview",
    "migrate:prod": "wrangler d1 migrations apply terminal-quest --remote",
    "deploy": "wrangler deploy",
    "deploy:preview": "wrangler versions upload --remote"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@cloudflare/vite-plugin": "^1.36.0",
    "@cloudflare/workers-types": "^4.20260506.1",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/types": "^20.5.0",
    "@mrbernnz/semantic-release-calver": "^0.3.1",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/error": "^4.0.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.5",
    "ajv": "^8.20.0",
    "better-sqlite3": "^12.9.0",
    "commitizen": "^4.3.1",
    "commitlint": "^20.5.2",
    "commitlint-config-gitmoji": "^2.3.1",
    "concurrently": "^9.2.1",
    "conventional-changelog-angular": "^8.3.1",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "cz-git": "^1.12.0",
    "date-fns": "^2.30.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "msw": "^2.14.3",
    "semantic-release": "^25.0.3",
    "semantic-release-gitmoji": "^1.6.9",
    "semver": "^7.7.4",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.88.0"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@msgpack/msgpack": "^3.1.3",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.17",
    "leven": "^4.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.4.3"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "dependenciesMeta": {
    "@biomejs/biome@2.4.10": {
      "unplugged": true
    }
  }
}
